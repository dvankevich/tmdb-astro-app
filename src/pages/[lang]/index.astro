---
export const prerender = false;

import { getCurrentLocale, getTmdbLanguage } from "../../lib/tmdb.ts";
import Layout from "../../layouts/Layout.astro";
import { t } from "../../lib/i18n";

const langFromUrl = Astro.currentLocale ?? "uk";
const lang = getCurrentLocale(langFromUrl);

const key = import.meta.env.TMDB_API_KEY;
const tmdbLang = getTmdbLanguage(lang);
const res = await fetch(
    `https://api.themoviedb.org/3/movie/popular?api_key=${key}&language=${tmdbLang}&page=1`,
);
const { results: movies } = await res.json();
const title = t("popularMovies", lang);
---

<Layout title={`${title} — ${lang.toUpperCase()}`}>
    <h1 class="text-4xl font-bold text-center py-12">{title}</h1>

    <!-- Переклади для перевірки -->
    <div class="text-center text-sm text-gray-400 mb-6">
        {t("currentLanguage", lang)}: <span
            class="font-mono bg-zinc-800 px-2 py-1 rounded">{lang}</span
        >
        <br />
        {t("tmdbLanguage", lang)}: <span
            class="font-mono bg-zinc-800 px-2 py-1 rounded">{tmdbLang}</span
        >
    </div>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-6 px-4">
        {
            movies.map((m: any) => (
                <div class="bg-zinc-800 rounded-xl overflow-hidden">
                    <img
                        src={`https://image.tmdb.org/t/p/w500${m.poster_path}`}
                        alt={m.title}
                        class="w-full"
                    />
                    <div class="p-4">
                        <h3 class="font-bold">{m.title}</h3>
                        <p class="text-sm text-gray-400">{m.release_date}</p>
                    </div>
                </div>
            ))
        }
    </div>
</Layout>

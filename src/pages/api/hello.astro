---
export const prerender = false;

import { t } from "../../lib/i18n.ts";

const langParam = Astro.url.searchParams.get("lang") || "uk"; // string

// Перевіряємо і приводимо до правильного типу
const lang: "uk" | "en" = langParam === "en" ? "en" : "uk"; // ← ключовий рядок
---

<div class="text-green-400 text-xl font-bold">
    {t("helloFromHtmx", lang)}! {lang === "uk" ? "Час" : "Time"}: {
        new Date().toLocaleTimeString(lang === "uk" ? "uk-UA" : "en-US")
    }
</div>
